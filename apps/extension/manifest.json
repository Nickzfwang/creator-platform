{
  "manifest_version": 3,
  "name": "Creator Platform - AI 內容收藏助手",
  "version": "1.0.0",
  "description": "一鍵收藏社群精華內容，AI 自動摘要分類",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://www.threads.net/*",
    "https://www.youtube.com/*",
    "https://www.instagram.com/*",
    "https://www.dcard.tw/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://www.threads.net/*",
        "https://www.youtube.com/*",
        "https://www.instagram.com/*",
        "https://www.dcard.tw/*",
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
