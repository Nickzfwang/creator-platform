# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/creator_platform?schema=public"
REDIS_URL="redis://localhost:6379"

# ─── Auth ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-me"
JWT_SECRET="your-jwt-secret-change-me"
UNSUBSCRIBE_SECRET="your-unsubscribe-secret-change-me"

# ─── OAuth Providers ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Social Platform APIs ───
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# ─── AI Services ───
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Stripe ───
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Email (Brevo) ───
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@creator-platform.com"
BREVO_SENDER_NAME="創作者平台"
BREVO_TEMPLATE_DAILY_SUMMARY=1
BREVO_TEMPLATE_NOTIFICATION=2

# ─── Storage (S3-compatible: MinIO / Cloudflare R2 / AWS S3) ───
# MinIO (dev):  STORAGE_ENDPOINT="http://localhost:9000"
# R2 (prod):    STORAGE_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="creator-platform-uploads"
STORAGE_REGION="auto"
STORAGE_PUBLIC_URL=""

# ─── AWS (legacy, optional — use Storage section above instead) ───
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-1"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_DOMAIN=""

# ─── App ───
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3001"
NODE_ENV="development"
